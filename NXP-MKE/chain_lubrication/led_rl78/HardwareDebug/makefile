# Add inputs and outputs from these tool invocations to the build variables
LINKER_OUTPUT_OUTPUTS += \
I2C.abs

LIBRARY_GENERATOR_OUTPUTTYPE_OUTPUTS += \
I2C.lib

CONVERTOR_OUTPUT_OUTPUTS += \
I2C.mot

OBJS := \
$(COMPILER_OBJS) \
$(INDIVIDUAL_COMPILER_OBJS) \
$(ASSEMBLER_OBJS) \
$(CUSTOM_OBJS)


# All Target
all: I2C.x I2C.udm $(CONVERTOR_OUTPUT_OUTPUTS) 
	@echo 'Build complete.'

I2C.mot: $(LINKER_OUTPUT_OUTPUTS) 
	@echo 'Invoking Converter: $@'
	rlink "I2C.abs" -subcommand="ConverterI2C.tmp"


I2C.abs: $(LIBRARY_GENERATOR_OUTPUTTYPE_OUTPUTS) $(OBJS) $(ALL_ASMS)
	@echo 'Invoking Linker: $@'
	rlink -subcommand="LinkerI2C.tmp"


I2C.lib: 
	@echo 'Invoking Library Generator: $@'
	lbgrl -subcommand="LibraryGeneratorI2C.tmp"

I2C.x: I2C.abs
	renesas_cc_converter I2C.abs I2C.x

I2C.udm: $(LINKER_OUTPUT_OUTPUTS) $(CONVERTOR_OUTPUT_OUTPUTS)
	udcollector -subcommand=udSubcommand.tmp -output=I2C.udm

# Other Targets
clean:
	-$(file > clean_file.tmp, $(LINKER_OUTPUT_OUTPUTS) $(LIBRARY_GENERATOR_OUTPUTTYPE_OUTPUTS) $(CONVERTOR_OUTPUT_OUTPUTS) $(OBJS) $(ALL_COMMON_DEPS) $(DSP_DEPS) $(DSP_UPPER_DEPS) $(OUTPUT_FILES))
	-@ xargs -P 2 -s 26000 -t -a clean_file.tmp $(RM)
	-@$(RM) clean_file.tmp
	@echo ''
	@echo 'Clean complete.'

.PHONY: all clean 
-include ../makefile.targets

